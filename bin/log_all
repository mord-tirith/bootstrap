#!/usr/bin/env bash
set -euo pipefail

OUTPUT_FILE="/tmp/log_all_file"
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/log_all"
STATE_FILE="$STATE_DIR/defaults"
SAVE_DEFAULTS=0
CLEAR_DEFAULTS=0
MAX_DEPTH=1
LIST=0
LANGS=()
FILES=()
LIST_NAMES=()

declare -A LIST_MATCHES=()
declare -A LIST_FOUND=()

err() {
	tput setaf 1
	printf '[ERROR] '
	tput sgr0
	printf '%s\n' "$*" >&2
	exit 1
}

warn() {
	tput setaf 3
	printf '[WARN] '
	tput sgr0
	printf '%s\n' "$*" >&2
}

log() {
	tput setaf 51
	printf '[INFO] '
	tput sgr0
	printf '%s\n' "$*" >&1
}

need_cmd() {
	command -v "$1" >/dev/null 2>&1 || err "Required command not found: $1"
}

add_file() {
	local file="$1"
	FILES+=("$file")
}

run_find() {
	if [ "$MAX_DEPTH" -eq 0 ]; then
		find . "${@}"
	else
		find . -maxdepth "$MAX_DEPTH" "${@}"
	fi
}

find_type() {
	local ext="$1"

	while IFS= read -r -d '' file; do
		add_file "$file"
	done < <(run_find -type f -name "*$ext" -print0)
}

write_log() {
	local file

	: > "$OUTPUT_FILE"
	for file in "$@"; do
		printf '========== START OF FILE: %s ==========\n' "$file" >> "$OUTPUT_FILE"
		cat -- "$file" >> "$OUTPUT_FILE"
		printf '\n=========== END OF FILE: %s ===========\n' "$file" >> "$OUTPUT_FILE"
	done
}

write_list_log() {
	local name
	local file

	: > "$OUTPUT_FILE"

	for name in "${LIST_NAMES[@]}"; do
		if [[ -n ${LIST_FOUND[$name]+x} ]]; then
			while IFS= read -r file; do
				[ -n "$file" ] || continue
				printf '========== START OF FILE: %s ==========\n' "$file" >> "$OUTPUT_FILE"
				cat -- "$file" >> "$OUTPUT_FILE"
				printf '\n=========== END OF FILE: %s ===========\n' "$file" >> "$OUTPUT_FILE"
			done <<< "${LIST_MATCHES[$name]}"
		else
				printf '########## MISSING FILE: %s ##########\n' "$name" >> "$OUTPUT_FILE"
				printf 'No matches for %s were found either in current dir or any subdirectory\n' "$name" >> "$OUTPUT_FILE"
				printf '########### END OF MISSING FILE MESSAGE ###########\n' "$name" >> "$OUTPUT_FILE"

		fi
	done

}

collect_list_files() {
	local file
	local base
	declare -A wanted=()

	for base in "${LIST_NAMES[@]}"; do
		wanted["$base"]=1
	done

	while IFS= read -r -d '' file; do
		base=${file##*/}
		if [[ -n "${wanted[$base]+x}" ]]; then
			add_file "$file"
			LIST_MATCHES["$base"]+="$file"$'\n'
			LIST_FOUND["$base"]=1
		fi
	done < <(run_find -type f -print0)
}

save_defaults() {
	mkdir -p "$STATE_DIR"
	printf '%s\n' "${LANGS[@]}" > "$STATE_FILE"
}

load_defaults() {
	if [ -f "$STATE_FILE" ]; then
		mapfile -t LANGS < "$STATE_FILE"
	fi
}

clear_defaults() {
	if [ -f "$STATE_FILE" ]; then
		rm -f -- "$STATE_FILE"
		log "Saved defaults cleared"
	else
		warn "No defaults file to remove"
	fi
}

usage() {
	cat << EOF
Usage: $0 [--save|-s] [--depth|-d] [--clean|-c] [--help|-h] (...)

Creates and opens a file containing a text dump of all files in current directory,
if given a programming language or specific extention, will limit itself only to those files

Flags:
	--save,		-s	Save listed languages for default behavior
	--clean,	-c	Removes saved language
	--depth,	-d	Specifies maximum depth of files searched
				if left as 0 will find all possible files
				in sub-directories
	--help,		-h	Shows this help message
	--list,		-l	Feed hard filenames to be included

	(...)			Anything written other than these flags
				will be treated as languages or extensions
				to be added.

				"c" will result in .c and .h files being
				added to the log.

				Not previously hardcoded arguments like
				"MD" will default to searching for files
				that have ".MD" extention.
EOF
exit 0
}

parse_args() {

	while [ "$#" -gt 0 ]; do
		case "$1" in
			-h|--help)
				usage
				;;
			-s|--save)
				SAVE_DEFAULTS=1
				shift
				;;
			-c|--clean)
				CLEAR_DEFAULTS=1
				shift
				;;
			-d|--depth|-maxdepth)
				[ "$#" -ge 2 ] || err "-d expects a number"

				case "$2" in
					''|*[!0-9]*)
						err "-d expects a non-negative integer"
						;;
				esac
				MAX_DEPTH="$2"
				shift 2
				;;
			-l|--list)
				if [ "$SAVE_DEFAULTS" -eq 1 ] || [ "$CLEAR_DEFAULTS" -eq 1 ] || \
					[ "$MAX_DEPTH" -ne 1 ] || [ "${#LANGS[@]}" -ne 0 ]; then
						err "-l is exclusionary and must be run without any other flags combined"
				fi

				LIST=1
				MAX_DEPTH=0
				shift
				
				[ "$#" -gt 0 ] || err "-l expects at least one literal filename"	
				LIST_NAMES=("$@")

				break
				;;
			*)
				LANGS+=("$1")
				shift
				;;
		esac
	done
	if [ "$SAVE_DEFAULTS" -eq 1 ] && [ "$CLEAR_DEFAULTS" -eq 1 ]; then
		err "-c and -s can't run together"
	fi
}

parse_langs() {
	for lang in "${LANGS[@]}"; do
		case "$lang" in
			c)
				find_type ".c"
				find_type ".h"
				;;
			c++|cpp)
				find_type ".h"
				find_type ".hh"
				find_type ".cc"
				find_type ".cpp"
				find_type ".hpp"
				;;
			py|python)
				find_type ".py"
				;;
			lua|nvim)
				find_type ".lua"
				;;
			sh|shell|script|bash)
				find_type ".sh"
				;;
			ts|typescript)
				find_type ".ts"
				;;
			*)
				log "Unknown language: '$lang', trying extension '.$lang'"
				find_type ".$lang"
				;;
		esac
	done
}

open_output() {
	if command -v xdg-open >/dev/null 2>&1; then
		xdg-open "$OUTPUT_FILE" >/dev/null 2>&1 &
	elif command -v open >/dev/null 2>&1; then
		open "$OUTPUT_FILE" >/dev/null 2>&1 &
	else
		printf '%s\n' "$OUTPUT_FILE"
	fi
}

main() {
	# Make sure all required cmds exist in this machine
	need_cmd cat
	need_cmd sort
	need_cmd find

	# Parse the arguments given to the run
	parse_args "$@"

	if [ "$LIST" -eq 1 ]; then
		log "Running list mode for '${LIST_NAMES[*]}'"
		collect_list_files
		write_list_log
		open_output
		exit 0
	fi

	# If this is a -c run, clean defaults and exit
	if [ "$CLEAR_DEFAULTS" -eq 1 ]; then
		clear_defaults
		exit 0
	fi

	# -s logic center:
	if [ "$SAVE_DEFAULTS" -eq 1 ]; then
		if [ "${#LANGS[@]}" -eq 0 ]; then # Stops -s from being used with no new defaults
			err "-s ran with no new defaults given"
		fi
		save_defaults # Stores given languages as new default
		log "Saving '${LANGS[*]}' as new default"
	fi
		
	# If no langs in array yet, load from default file
	if [ "${#LANGS[@]}" -eq 0 ]; then
		load_defaults
	fi

	if [ "${#LANGS[@]}" -eq 0 ]; then # If there are STILL 0 languages in array, load every file
		log "Running log for all files"
		while IFS= read -r -d '' file; do
			add_file "$file"
		done < <(run_find -type f -print0)
	else
		log "Running log for '${LANGS[*]}' files"
		parse_langs # Otherwise, load files by parsing languages in array
	fi

	if [ "${#FILES[@]}" -eq 0 ]; then
		warn "No matching files found"
		exit 0
	fi

	mapfile -t FILES < <(printf '%s\n' "${FILES[@]}" | sort -u)

	write_log "${FILES[@]}"
	
	open_output
}

main "$@"
